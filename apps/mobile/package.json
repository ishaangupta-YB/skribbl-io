{
  "name": "@skribbl/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --web",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export -p web",
    "deploy:web": "wrangler pages deploy dist --project-name skribbl-cloud",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config features/game/vitest.config.ts && vitest run --config vitest.qa.config.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "2.6.2",
    "@skribbl/shared": "workspace:*",
    "expo": "~56.0.12",
    "expo-audio": "~56.0.12",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "lucide-react-native": "^1.21.0",
    "nativewind": "^4.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
