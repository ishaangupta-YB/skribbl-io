    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "~6.0.3",
    "vitest": "3.0.5",
    "wrangler": "~4.10.0",
    "ws": "^8.18.0"
