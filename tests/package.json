  "dependencies": {
    "@skribbl/shared": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "serve": "^14.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "3.2.6",
    "ws": "^8.18.0"
  }
